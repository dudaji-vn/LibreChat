{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm run build*)",
      "Bash(npm run frontend*)",
      "Bash(npm run backend*)",
      "Bash(npm run smart-reinstall)",
      "Bash(npm run reinstall)",
      "Bash(npm run lint*)",
      "Bash(npm run test*)",
      "Bash(npm test*)",
      "Bash(npm ci)",
      "Bash(npm audit*)",
      "Bash(npx jest*)",
      "Bash(npx tsc*)",
      "Bash(npx eslint*)",
      "Bash(npx prettier*)",
      "Bash(npx turbo*)",
      "Bash(cd api && npx jest*)",
      "Bash(cd packages/api && npx jest*)",
      "Bash(cd packages/data-schemas && npx jest*)",
      "Bash(cd packages/data-provider && npx jest*)",
      "Bash(cd client && npx jest*)",
      "Bash(gh pr view*)",
      "Bash(gh pr list*)",
      "Bash(gh pr checks*)",
      "Bash(gh pr diff*)",
      "Bash(gh issue view*)",
      "Bash(gh issue list*)",
      "Bash(gh run view*)",
      "Bash(gh run list*)",
      "Bash(gh run watch*)",
      "Bash(gh repo view*)",
      "Bash(gh api repos/*)",
      "Bash(gh workflow list*)",
      "Bash(gh workflow view*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git fetch*)",
      "Bash(git stash list)",
      "Bash(git remote -v)",
      "Bash(git remote get-url*)",
      "Bash(git rev-parse*)",
      "Bash(git tag -l*)",
      "Bash(git tag --list*)",
      "Bash(git config --get*)",
      "Bash(grep:*)",
      "Bash(find . *)",
      "Bash(ls *)",
      "Bash(jq *)",
      "Bash(echo *)",
      "Bash(wc *)",
      "Bash(sort *)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git branch -D*)",
      "Bash(git tag -d nufi-v*)",
      "Bash(git push origin --delete nufi-v*)",
      "Bash(gh pr close*)",
      "Bash(rm -rf*)"
    ]
  }
}
